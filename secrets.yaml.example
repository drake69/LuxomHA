# =============================================================================
#  secrets.yaml  —  COPY this file to  secrets.yaml  and fill in the values.
#  secrets.yaml is NOT committed to git (see .gitignore).
# =============================================================================
#
#  MIND THE QUOTES:
#   - Values used in normal ESPHome fields (wifi, mqtt) are plain strings:
#     NO inner quotes.
#   - Values that end up in a `globals: initial_value` are inserted into C++ code:
#     * TEXT (luxom_host, luxom_probe_modules, luxom_covers) MUST keep the inner
#       double quotes -> write it as  '"...value..."'.
#     * NUMBERS (luxom_port, luxom_probe_out_max) must be a QUOTED string ->
#       write  "2301"  (ESPHome requires a string for initial_value).
# =============================================================================

# ---- Wi-Fi (plain strings) ----
wifi_ssid: "MYWIFI"
wifi_password: "wifi-password"

# ---- Home Assistant MQTT broker (plain strings) ----
mqtt_host: "192.168.0.10"
mqtt_user: "mqtt"
mqtt_pass: "mqtt-password"

# ---- Luxom DS65L IP interface ----
luxom_host: '"192.168.0.50"'     # <-- inner quotes required (goes into a global)
luxom_port: "2301"               # quoted string. ELAN docs DS65L=2301; openHAB=2300.
                                 # If the connection fails, try "2300".

# ---- Address range for the active *P scan ("scan bus" button) ----
# Modules to probe, comma-separated. May be digits and/or letters.
luxom_probe_modules: '"1,2,3,4,5,6,7,8,9,A,B,C,D,E,F,G,H"'   # inner quotes required
luxom_probe_out_max: "16"        # quoted string; probe outputs 01..16 per module

# ---- Shutters (PHASE 2) ----
# Get the up/down addresses with luxom_cover_discovery.yaml (PHASE 1), then list
# them here. Format:  Name|UP|DOWN  separated by ';'  (UP/DOWN are "M,OO").
# Leave '""' if you have no shutters.
luxom_covers: '""'
# Example with two shutters:
# luxom_covers: '"Kitchen|2,03|2,04 ; Bedroom|2,05|2,06"'

# ---- OTA ----
ota_password: "change-this-ota-password"   # protects wireless firmware updates

# ---- Optional: fixed IP for the ESP32 (for rock-solid wireless OTA) ----
# Plain strings, no inner quotes. Only needed if you uncomment the `manual_ip`
# block in luxom_gateway.yaml. Otherwise the gateway uses DHCP and is reached by
# name (luxom-gateway.local). Easiest alternative: a DHCP reservation on the router.
# esp_static_ip: "192.168.0.60"
# esp_gateway:   "192.168.0.1"
# esp_subnet:    "255.255.255.0"
